<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard | Brand</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { font-family: sans-serif; background-color: #f7f8f9; margin: 0; padding: 0; }
        .nav { background: #24292e; color: white; padding: 15px 5%; display: flex; justify-content: space-between; }
        .container { max-width: 800px; margin: 40px auto; background: white; padding: 30px; border-radius: 8px; border: 1px solid #e3e8ee; }
        h2 { color: #1c1c1c; margin-bottom: 20px; }
        input { width: 100%; padding: 12px; margin-bottom: 15px; border: 1px solid #dee2e6; border-radius: 6px; }
        .btn-add { width: 100%; padding: 12px; background: #0d6efd; color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; }
        
        .admin-list { margin-top: 30px; }
        .list-item { display: flex; justify-content: space-between; padding: 15px; border-bottom: 1px solid #eee; align-items: center; }
        .btn-delete { background: #ff4d4d; color: white; border: none; padding: 8px 15px; border-radius: 4px; cursor: pointer; }
    </style>
</head>
<body>
    <div class="nav">
        <b><i class="fa-solid fa-gear"></i> Admin Dashboard</b>
        <a href="/products" style="color: white; text-decoration: none;">View Store</a>
    </div>

    <div class="container">
        <h2>Add New Product</h2>
        <form action="/api/products" method="POST">
            <input type="text" name="name" placeholder="Product Name" required>
            <input type="number" name="price" placeholder="Price ($)" required>
            <input type="text" name="image" placeholder="Image URL (https://...)" required>
            <button type="submit" class="btn-add">Publish Product</button>
        </form>

        <div class="admin-list">
            <h3>Manage Inventory</h3>
            <% products.forEach(product => { %>
                <div class="list-item">
                    <span><%= product.name %> - <b>$<%= product.price %></b></span>
                    <form action="/products/delete/<%= product._id %>" method="POST" onsubmit="return confirm('Pakka?')">
                        <button type="submit" class="btn-delete"><i class="fa-solid fa-trash"></i> Delete</button>
                    </form>
                </div>
            <% }) %>
        </div>
    </div>
</body>
</html>

