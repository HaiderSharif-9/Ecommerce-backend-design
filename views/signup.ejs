<!DOCTYPE html>
<html>
<head>
    <title>Sign Up | Brand Store</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        /* Same Design as Login */
        body { font-family: sans-serif; background-color: #f7f8f9; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .auth-card { background: white; padding: 40px; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); border: 1px solid #e3e8ee; width: 100%; max-width: 400px; text-align: center; }
        .brand-logo { color: #0d6efd; font-size: 28px; font-weight: bold; margin-bottom: 25px; display: block; text-decoration: none; }
        h2 { margin-bottom: 20px; color: #1c1c1c; font-size: 20px; }
        input { width: 100%; padding: 12px; margin-bottom: 15px; border: 1px solid #dee2e6; border-radius: 6px; box-sizing: border-box; outline: none; }
        .btn-auth { width: 100%; padding: 12px; background: #28a745; color: white; border: none; border-radius: 6px; font-weight: bold; cursor: pointer; font-size: 16px; }
        .switch-link { margin-top: 20px; display: block; color: #8b96a5; font-size: 14px; text-decoration: none; }
        .switch-link b { color: #0d6efd; }
    </style>
</head>
<body>
    <div class="auth-card">
        <a href="/" class="brand-logo"><i class="fa-solid fa-shopping-bag"></i> Brand</a>
        <h2>Create New Account</h2>
        
        <form action="/signup" method="POST">
            <input type="text" name="username" placeholder="Full Name" required>
            <input type="email" name="email" placeholder="Email Address" required>
            <input type="password" name="password" placeholder="Create Password" required>
            <button type="submit" class="btn-auth">Register Now</button>
        </form>
        
        <a href="/login" class="switch-link">Already have an account? <b>Login</b></a>
    </div>
</body>
</html>

